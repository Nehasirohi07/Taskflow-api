services:
  mysql:
    image: mysql:8.4
    container_name: taskflow_mysql

    environment:
      MYSQL_ROOT_PASSWORD: root123
      MYSQL_DATABASE: taskflow

    ports:
      - "3309:3306"

    volumes:
      - mysql_data:/var/lib/mysql

  backend:
    build: .

    container_name: taskflow_backend

    depends_on:
      - mysql

    ports:
      - "5051:5051"

    environment:
      DB_USER: root
      DB_PASSWORD: root123
      DB_HOST: mysql
      DB_PORT: 3306
      DB_NAME: taskflow
      JWT_SECRET: myjwtsecretkey000
      PORT: 5051

volumes:
  mysql_data: